rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: only the authenticated user can read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Categories subcollection
      match /categories/{categoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Pomodoro presets subcollection
      match /pomodoro_presets/{presetId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // pending_verifications: authenticated user can create, read, and delete their own doc.
    // Update is not allowed — docs are only created on sign-up and deleted after verification.
    match /pending_verifications/{userId} {
      allow create, read, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if false;
    }
  }
}

